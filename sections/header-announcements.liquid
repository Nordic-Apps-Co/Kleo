<div class="kleo-announcement-bar">
  <div class="kleo-announcement-bar__inner">
    <span class="kleo-announcement-bar__item">
      <img src="{{ 'icon-envelope.svg' | asset_url }}" width="14" height="14" style="vertical-align:middle;margin-right:6px" alt="">Brug for hjælp?
    </span>
    <span class="kleo-announcement-bar__item">60 dages fuld returret | Hurtig levering</span>
    <span class="kleo-announcement-bar__item">
      <img src="{{ 'denmark-flag.svg' | asset_url }}" width="16" height="16" style="vertical-align:middle;margin-right:6px" alt="Dansk flag">Dansk virksomhed
    </span>
  </div>
</div>

{% stylesheet %}
  .kleo-announcement-bar {
    background-color: #1b2a4a;
    color: #ffffff;
    border-block-end: 1px solid #2a3a5a;
  }

  .kleo-announcement-bar__inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-block: 10px;
    padding-inline: var(--page-margin);
  }

  .kleo-announcement-bar__item {
    font-size: 13px;
    line-height: 1.2;
    white-space: nowrap;
    font-variant-emoji: emoji;
  }

  @media screen and (max-width: 749px) {
    .kleo-announcement-bar__inner {
      gap: 0.5rem;
      padding-block: 8px;
    }

    .kleo-announcement-bar__item {
      font-size: 11px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [],
  "enabled_on": {
    "groups": ["header"]
  },
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
