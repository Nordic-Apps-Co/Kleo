<div class="kleo-announcement-bar">
  <div class="kleo-announcement-bar__inner">
    {% if section.settings.message_1 != blank %}
      <span class="kleo-announcement-bar__item">{{ section.settings.message_1 }}</span>
    {% endif %}
    {% if section.settings.message_2 != blank %}
      <span class="kleo-announcement-bar__item">{{ section.settings.message_2 }}</span>
    {% endif %}
    {% if section.settings.message_3 != blank %}
      <span class="kleo-announcement-bar__item">{{ section.settings.message_3 }}</span>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .kleo-announcement-bar {
    background-color: #1b2a4a;
    color: #ffffff;
    border-block-end: 1px solid #2a3a5a;
  }

  .kleo-announcement-bar__inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-block: 10px;
    padding-inline: var(--page-margin);
  }

  .kleo-announcement-bar__item {
    font-size: 13px;
    line-height: 1.2;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .kleo-announcement-bar__inner {
      gap: 0.5rem;
      padding-block: 8px;
    }

    .kleo-announcement-bar__item {
      font-size: 11px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "message_1",
      "label": "Message 1",
      "default": "✉ Brug for hjælp?"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Message 2",
      "default": "60 dages fuld returret | Hurtig levering"
    },
    {
      "type": "text",
      "id": "message_3",
      "label": "Message 3",
      "default": "🇩🇰 Dansk virksomhed"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
